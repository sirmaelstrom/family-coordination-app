@page "/"
@model FamilyCoordinationApp.Pages.LandingModel
@{
    ViewData["Title"] = "Family Kitchen";
}
<div class="prose" style="max-width: 640px;">
    <div class="brand">
        <div class="brand-mark">🏡</div>
        <h1>Family Kitchen</h1>
        <p class="muted">Meal planning made simple for busy families</p>
    </div>

    <h2>What is this?</h2>
    <p>
        A collaborative meal planning app designed for families. Plan your weekly meals together,
        manage recipes, and automatically generate shopping lists organized by store section.
    </p>

    <h2>Features</h2>
    <ul>
        <li><strong>Recipe Management</strong> — Add recipes manually or import from popular cooking sites</li>
        <li><strong>Meal Planning</strong> — Weekly meal calendar</li>
        <li><strong>Smart Shopping Lists</strong> — Auto-generated from your meal plan, organized by aisle</li>
        <li><strong>Family Collaboration</strong> — Real-time sync so everyone stays on the same page</li>
        <li><strong>Mobile-Friendly</strong> — Works great on your phone at the grocery store</li>
    </ul>

    <div class="center mt">
        <a class="btn btn-primary" href="/account/login">Sign In to Get Started</a>
    </div>

    <p class="muted small center mt">Currently in beta testing. Built for families, by families.</p>
</div>
