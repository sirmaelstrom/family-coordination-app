# SvelteKit SPA (de-Blazor WP-12: served at root) — source is frontend/app/src/; the CopyAppSpa
# msbuild target copies frontend/app/build/** into wwwroot/ root, so those outputs are ignored here.
src/FamilyCoordinationApp/wwwroot/_app/
src/FamilyCoordinationApp/wwwroot/index.html
src/FamilyCoordinationApp/wwwroot/manifest.json
src/FamilyCoordinationApp/wwwroot/service-worker.js
frontend/app/build/
frontend/app/.svelte-kit/
node_modules/
