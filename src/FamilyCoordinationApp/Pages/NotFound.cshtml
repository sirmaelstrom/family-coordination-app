@page "/not-found"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@{
    ViewData["Title"] = "Not Found - Family Kitchen";
}
@* De-Blazor WP-10: static Razor Page replacing NotFound.razor. Target of
   UseStatusCodePagesWithReExecute("/not-found"); always renders a body. *@
<div class="prose">
    <h1>Not Found</h1>
    <p>Sorry, the content you are looking for does not exist.</p>
    <p class="mt"><a class="btn btn-outline" href="/">Back to Home</a></p>
</div>
