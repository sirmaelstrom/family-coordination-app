# PostgreSQL
POSTGRES_USER=familyapp
POSTGRES_DB=familyapp
# Password is in secrets/postgres_password (Docker secret), not in .env

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Environment
ASPNETCORE_ENVIRONMENT=Development

# Chores weekly Discord digest (v1.1)
# Shared secret for the cron-triggered digest run endpoint. Leave BLANK to disable the endpoint entirely
# (it returns 503 when unconfigured). Generate a long random value, e.g.: openssl rand -hex 32
CHORES_DIGEST_TRIGGER_TOKEN=
# The digest fires via EXTERNAL cron (not an in-process scheduler). Add an hourly crontab line on the host
# that POSTs the run endpoint with the token in the X-Digest-Trigger-Token header (never the query string).
# The endpoint is idempotent + self-gated to each household's configured local send weekday/hour, so an
# hourly tick is safe. Example crontab entry (top of every hour):
#   0 * * * * curl -fsS -X POST https://<your-host>/api/chores/digest/run -H "X-Digest-Trigger-Token: <TOKEN>" >/dev/null 2>&1

# Production paths (production server ZFS)
# Uncomment and set for production deployment
# POSTGRES_DATA_PATH=/themanjesus/docker-data/family-app/postgres
# APP_UPLOADS_PATH=/themanjesus/docker-data/family-app/uploads
# APP_LOGS_PATH=/themanjesus/docker-data/family-app/logs
# SSL_CERT_PATH=/themanjesus/docker-data/certs
