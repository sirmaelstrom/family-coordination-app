# Environment
.env
.env.local
.env.*.local

# Docker secrets
secrets/

# Docker volumes
postgres-data/
app-uploads/
app-logs/
# root-anchored so it matches ONLY the runtime bind-mount dir, NOT src/.../Data/.
# An unanchored `data/` matches `Data/` case-insensitively on Windows and silently
# strands new entity/config source files (bit us on chores v1.1 — CI red, local green).
/data/

# SSL certs (except example)
nginx/certs/*.pem
nginx/certs/*.key
!nginx/certs/.gitkeep

# IDE
.idea/
.vs/
*.user
*.suo

# Build artifacts
**/bin/
**/obj/
**/publish/

